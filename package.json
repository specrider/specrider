{
  "name": "specrider",
  "private": true,
  "version": "0.1.1",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "pnpm typecheck && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "biome check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:components": "vitest run --coverage --config vitest.coverage.components.config.ts",
    "test:coverage:utilities": "vitest run --coverage --config vitest.coverage.utilities.config.ts",
    "test:watch": "vitest",
    "test:perf": "playwright test tests/perf.spec.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
